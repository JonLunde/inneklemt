---
import type { MonthGroup } from '../utils/groupByMonth';
import DayCard from './DayCard.astro';

interface Props {
  monthGroup: MonthGroup;
}

const { monthGroup: { monthName, groups } } = Astro.props;

const tooltipText = 'Fridager du får per feriedag du tar ut. Høyere er bedre.';

const groupStats = groups.map((group) => {
  const inneklemtDays = group.filter((d) => d.description === 'inneklemt');
  const inneklemtCount = inneklemtDays.length;
  const nonInneklemtDays = group.length - inneklemtCount;
  const ratioNum = nonInneklemtDays / inneklemtCount;
  const valueRatio = ratioNum.toFixed(1);
  const badgeStyle =
    ratioNum >= 3
      ? 'background:#15803D;color:#fff'
      : ratioNum >= 2
        ? 'background:#16A34A;color:#fff'
        : 'background:#22C55E;color:#fff';
  const dayWord = inneklemtCount === 1 ? 'inneklemt dag' : 'inneklemte dager';
  const badgeLabel = `${valueRatio} fridager per feriedag. ${tooltipText}`;
  return { group, inneklemtCount, nonInneklemtDays, valueRatio, badgeStyle, dayWord, badgeLabel };
});

const totalInneklemt = groupStats.reduce((sum, gs) => sum + gs.inneklemtCount, 0);
const totalDayWord = totalInneklemt === 1 ? 'inneklemt dag' : 'inneklemte dager';
const isMultiGroup = groups.length > 1;
---

<details class="group bg-surface border border-border rounded-xl overflow-hidden shadow-sm">
  <summary class="flex items-center justify-between px-5 py-4 cursor-pointer hover:bg-bg transition-colors">
    <span class="font-semibold text-text">
      {monthName}
      <span class="text-text-muted font-normal text-sm ml-2">· {totalInneklemt} {totalDayWord}</span>
    </span>
    <div class="flex items-center gap-3 flex-shrink-0">
      <svg
        class="w-5 h-5 text-text-muted transition-transform duration-200 group-open:rotate-180"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </summary>

  <div class="border-t border-border p-4 space-y-3">
    {groupStats.map((gs) => (
      <div class="rounded-lg border border-border overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2.5 bg-bg border-b border-border">
          <span class="text-sm font-medium text-text-muted">{gs.inneklemtCount} {gs.dayWord}</span>
          <div class="tooltip-anchor">
            <span
              style={gs.badgeStyle}
              class="text-sm font-bold px-2.5 py-1 rounded cursor-help select-none"
              tabindex="0"
              role="img"
              aria-label={gs.badgeLabel}
              title={tooltipText}
            >
              {gs.valueRatio}×
            </span>
            <div class="tooltip-content" aria-hidden="true">
              {tooltipText}
            </div>
          </div>
        </div>
        <div class="divide-y divide-border">
          {gs.group.map((day) => <DayCard day={day} />)}
        </div>
      </div>
    ))}
  </div>
</details>
