---
import ValueBadge from './ValueBadge.astro';

const faqs = [
  {
    question: 'Hva er en inneklemt dag?',
    answer:
      'En inneklemt dag er en arbeidsdag som ligger mellom en helligdag og en helg. Ved å ta fri denne arbeidsdagen kan du få en lengre periode med ferie.',
  },
  {
    question: 'Hva er formålet med denne siden?',
    answer:
      'Formålet med siden er å gi en enkel oversikt over årets inneklemte dager, slik at du kan få mest mulig utbytte av feriedagene dine.',
  },
  {
    question: 'Hva betyr ×-indikatoren?',
    questionPrefix: 'Hva betyr ',
    questionSuffix: '-indikatoren?',
    answer:
      'Indikatoren viser hvor mye en inneklemt dag er verdt. En høyere score betyr at du får mer sammenhengende fri for hver feriedag du bruker.',
    showBadge: true,
  },
  {
    question: 'Støtter siden flere år?',
    answer:
      'Ja, du kan bla gjennom årstallene ved å klikke på pilene øverst på siden.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<section class="mt-16 pt-10 border-t border-border">
  <h2 class="text-xl font-semibold text-text mb-6">Vanlige spørsmål</h2>
  <dl class="space-y-6">
    {faqs.map((faq) => (
      <div>
        <dt class="font-medium text-text mb-1 flex items-center gap-1 flex-wrap">
          {faq.showBadge
            ? <>{faq.questionPrefix}<ValueBadge ratio={3} aria-hidden="true" />{faq.questionSuffix}</>
            : faq.question}
        </dt>
        <dd class="text-text-muted leading-relaxed">{faq.answer}</dd>
      </div>
    ))}
  </dl>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
